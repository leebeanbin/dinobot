# ──────────────────────────────────────────────────────────────────
# DinoBot 환경 변수 예시
# 실제 값을 채운 뒤 .env 파일로 복사해 사용하세요.
# ──────────────────────────────────────────────────────────────────

# Discord Bot
DISCORD_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DEFAULT_DISCORD_CHANNEL_ID=

# Notion
NOTION_TOKEN=
FACTORY_TRACKER_DB_ID=
BOARD_DB_ID=

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=dinobot

# Server
HOST=0.0.0.0
PORT=8889
TIMEZONE=Asia/Seoul
WEBHOOK_SECRET=my-notion-webhook-secret

# ──────────────────────────────────────────────────────────────────
# CareerOS Integration
# ──────────────────────────────────────────────────────────────────

# URL of the CareerOS Spring Boot backend
CAREEROS_API_URL=http://localhost:8080

# Service-account JWT token issued by CareerOS (Authorization: Bearer ...)
CAREEROS_API_TOKEN=

# Must match app.dinobot.webhook-secret in CareerOS application.yml
CAREEROS_WEBHOOK_SECRET=

# Discord channel ID where daily job digests are posted
DIGEST_CHANNEL_ID=

# ──────────────────────────────────────────────────────────────────
# Telegram (채널 자체는 CareerOS TelegramNotificationChannel이 직접 처리)
# dinobot은 설정값을 참조용으로 보관하고 MCP 툴에서 활성화 여부를 제어합니다.
# ──────────────────────────────────────────────────────────────────

# Telegram Bot token (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# Telegram 수신 채팅방 또는 채널 ID (예: -1001234567890)
TELEGRAM_CHAT_ID=
